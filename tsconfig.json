{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@engine/*": ["src/engine/*"],
      "@generator/*": ["src/generator/*"],
      "@store/*": ["src/store/*"],
      "@hooks/*": ["src/hooks/*"],
      "@levels/*": ["src/levels/*"],
      "@persistence/*": ["src/persistence/*"]
    }
  }
}
