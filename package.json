{
  "name": "arrout",
  "version": "1.3.3",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build:android": "./scripts/build-local.sh android prod",
    "build:android:preview": "./scripts/build-local.sh android",
    "build:ios": "./scripts/build-local.sh ios prod",
    "build:ios:preview": "./scripts/build-local.sh ios",
    "build:web": "./scripts/build-local.sh web",
    "build:web:preview": "./scripts/build-local.sh web --no-zip",
    "postinstall": "node node_modules/@shopify/react-native-skia/scripts/install-skia.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.9",
    "expo-asset": "~55.0.10",
    "expo-audio": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-haptics": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.10",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "expo-constants": "~55.0.9"
